<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controllers.AgentDashboardController">
    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <HBox alignment="CENTER" style="-fx-padding: 20 0 10 0;">
                <Label text="ICRS - AGENT WORKSPACE" style="-fx-font-family: 'Century Gothic'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-letter-spacing: 2;" />
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="10" style="-fx-background-color: #1a1c24;">
            <padding><Insets top="30" right="15" bottom="15" left="15"/></padding>
            <Label text="AGENTIC ICRS" textFill="#3498db" style="-fx-font-size: 25; -fx-font-weight: bold; -fx-padding: 0 0 20 0;" />
            <Button maxWidth="Infinity" text="Workspace" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" text="Logout" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-cursor: hand;" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #ffffff;">
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label fx:id="welcomeLabel" text="Welcome, Agent" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER" style="-fx-background-color: #e8f4f8; -fx-padding: 10; -fx-background-radius: 10;">
                    <Label text="Assigned Complaints" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;" />
                    <Label fx:id="totalCountLabel" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                </VBox>
            </HBox>

            <TableView fx:id="complaintsTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dcdde1;">
                <columns>
                    <TableColumn fx:id="idCol" text="Complaint ID" prefWidth="100" />
                    <TableColumn fx:id="descCol" text="Description" prefWidth="400" />
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="150" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15">
                <Button fx:id="updateStatusBtn" onAction="#handleUpdateStatus" text="Update Status" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
                <Button onAction="#handleDelete" text="Delete Complaint" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </center>
</BorderPane>