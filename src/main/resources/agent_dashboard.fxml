<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #f0f2f5;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.complaint.system.controllers.AgentDashboardController">
    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <HBox alignment="CENTER" style="-fx-padding: 20 0 10 0;">
                <Label text="ICRS - AGENT WORKSPACE"
                       style="-fx-font-family: 'Century Gothic'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="10" style="-fx-background-color: #1a1c24;">
            <padding><Insets top="30" right="15" bottom="15" left="15"/></padding>
            <Label text="AGENTIC ICRS" textFill="#3498db"
                   style="-fx-font-size: 25; -fx-font-weight: bold; -fx-padding: 0 0 20 0;" />
            <Button maxWidth="Infinity" text="Workspace"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-cursor: hand;" />
        </VBox>
    </left>

    <center>
        <VBox spacing="15" style="-fx-padding: 25; -fx-background-color: #ffffff;">

            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label fx:id="welcomeLabel" text="Welcome, Agent"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER"
                      style="-fx-background-color: #e8f4f8; -fx-padding: 10; -fx-background-radius: 10;">
                    <Label text="Assigned Complaints" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;" />
                    <Label fx:id="totalCountLabel" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f8f9fa; -fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8;">
                <Label text="Filter:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <ComboBox fx:id="statusFilter"   promptText="Status"   prefWidth="120" />
                <ComboBox fx:id="priorityFilter" promptText="Priority" prefWidth="120" />
                <ComboBox fx:id="sortByFilter"   promptText="Sort By"  prefWidth="130" />
                <Button text="Apply Filter" onAction="#handleFilter"
                        style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 14; -fx-background-radius: 6; -fx-cursor: hand;" />
                <Button text="Reset" onAction="#handleResetFilter"
                        style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-cursor: hand;" />
            </HBox>

            <TableView fx:id="complaintsTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dcdde1;">
                <columns>
                    <TableColumn fx:id="idCol"       text="Complaint ID" prefWidth="90"  />
                    <TableColumn fx:id="descCol"     text="Description"  prefWidth="290" />
                    <TableColumn fx:id="statusCol"   text="Status"       prefWidth="110" />
                    <TableColumn fx:id="priorityCol" text="Priority"     prefWidth="90"  />
                    <TableColumn fx:id="notesCol"    text="Notes"        prefWidth="280" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button fx:id="updateStatusBtn" onAction="#handleUpdateStatus" text="Update Status"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-padding: 9 18; -fx-background-radius: 8; -fx-cursor: hand;" />
                <Button onAction="#handleUpdateNotes" text="Add / Edit Notes"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-padding: 9 18; -fx-background-radius: 8; -fx-cursor: hand;" />
                <Button onAction="#handleDelete" text="Delete Complaint"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-padding: 9 18; -fx-background-radius: 8; -fx-cursor: hand;" />
            </HBox>

        </VBox>
    </center>
</BorderPane>