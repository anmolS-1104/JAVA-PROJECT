<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="root-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.RegisterController">

    <VBox alignment="CENTER" spacing="18.0" maxWidth="450" maxHeight="550" styleClass="card">

        <Label text="Customer Registration" styleClass="title-label" />

        <Label fx:id="messageLabel" visible="false" />

        <TextField fx:id="nameField" promptText="Full Name" maxWidth="320" />
        <TextField fx:id="emailField" promptText="Email Address" maxWidth="320" />
        <TextField fx:id="phoneField" promptText="Phone Number" maxWidth="320" />
        <PasswordField fx:id="passwordField" promptText="Password" maxWidth="320" />
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" maxWidth="320" />

        <Button text="Register" onAction="#handleRegister" maxWidth="320" styleClass="action-button" />

        <Hyperlink text="Back to Login" onAction="#handleBackToLogin" />

    </VBox>
</StackPane>