<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f0f2f5;"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.complaint.system.ComplaintController">

    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <children>
                <HBox alignment="CENTER" style="-fx-padding: 20 0 10 0;">
                    <children>
                        <Label text="INTELLIGENT COMPLAINT SYSTEM"
                               style="-fx-font-family: 'Century Gothic'; -fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-letter-spacing: 3;" />
                    </children>
                </HBox>

                <Pane fx:id="tickerPane" prefHeight="35.0" prefWidth="1000.0" style="-fx-background-color: #2c3e50;">
                    <children>
                        <Label fx:id="movingLabel" layoutY="8.0"
                               text="Creators: Akshita Mukhia, Amaan Saxena, Aman Sumeet Saxena, Anmol Shinde from  SIT AIML Department 2026"
                               textFill="WHITE" style="-fx-font-family: 'Segoe UI'; -fx-font-size: 14; -fx-font-weight: bold;" />
                    </children>
                </Pane>
            </children>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="10" style="-fx-background-color: #1a1c24;">
            <padding><Insets top="30" right="15" bottom="15" left="15"/></padding>
            <children>
                <Label text="AGENTIC ICRS" textFill="#3498db"
                       style="-fx-font-size: 25; -fx-font-weight: bold; -fx-padding: 0 0 20 0;" />
                <Button maxWidth="Infinity" text="🏠 Dashboard"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" />
                <Button maxWidth="Infinity" text="📊 Analytics"
                        style="-fx-background-color: transparent; -fx-text-fill: #95a5a6; -fx-cursor: hand;" />
                <Button maxWidth="Infinity" text="🕒 History"
                        style="-fx-background-color: transparent; -fx-text-fill: #95a5a6; -fx-cursor: hand;" />
                <Region VBox.vgrow="ALWAYS" />
                <Separator opacity="0.2" />
                <Button maxWidth="Infinity" text="🚪 Logout"
                        style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-cursor: hand;" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #ffffff;">
            <children>
                <VBox spacing="5">
                    <Label text="New Resolution Request"
                           style="-fx-font-size:30 ; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <Label text="Enter details below. Our AI Agent will route your complaint automatically."
                           style="-fx-text-fill: #7f8c8d;" />
                </VBox>

                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 30;">
                    <children>
                        <Label text="Complaint Description"
                               style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 14;" />

                        <TextArea fx:id="complaintInput" prefHeight="220.0"
                                  promptText="Describe the issue... (e.g., 'Urgent refund required for order #123')" wrapText="true"
                                  style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dcdde1; -fx-font-size: 14;" />

                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <children>
                                <Button onAction="#handleFileUpload" text="📁 Attach Proof (Photo/Doc)"
                                        style="-fx-background-color: #f1f2f6; -fx-text-fill: #2f3542; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 8 15;" />
                                <Label fx:id="fileNameLabel" text="No file attached" textFill="#95a5a6" />
                            </children>
                        </HBox>

                <Button onAction="#handleSubmit" prefHeight="50" prefWidth="250" text="Submit to AI Agent"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" />
                <Label fx:id="statusLabel" text="Ready" />
            </children>
        </VBox>
    </center>

</BorderPane>