<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.ComplaintController">

    <top>
        <HBox spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Text fill="WHITE" text="ICRS | Intelligent Complaint Resolution System" style="-fx-font-weight: bold; -fx-font-size: 18;" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="180.0" spacing="10" style="-fx-background-color: #34495e; -fx-padding: 15;">
            <Button maxWidth="Infinity" text="🏠 Dashboard" style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
            <Button maxWidth="Infinity" text="📁 My History" style="-fx-background-color: transparent; -fx-text-fill: white;" />
            <Separator />
            <Button maxWidth="Infinity" text="⚙ Settings" style="-fx-background-color: transparent; -fx-text-fill: white;" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #ffffff;">
            <children>
                <Label layoutY="25.0" text="ICRS - Intelligent Dashboard" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </Pane>

        <Label layoutX="50.0" layoutY="110.0" text="Describe your complaint:">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <TextArea fx:id="complaintInput" layoutX="50.0" layoutY="140.0" prefHeight="200.0" prefWidth="600.0" promptText="Type here..." wrapText="true" />

        <Button fx:id="submitBtn" layoutX="50.0" layoutY="360.0" mnemonicParsing="false"
                onAction="#handleSubmit" prefHeight="40.0" prefWidth="150.0"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" text="Submit to AI" />

        <Label fx:id="statusLabel" layoutX="50.0" layoutY="420.0" text="Status: Waiting for input..." textFill="#7f8c8d">
            <font>
                <Font name="System Italic" size="14.0" />
            </font>
        </Label>
    </children>
</AnchorPane>