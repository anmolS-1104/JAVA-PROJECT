<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.ComplaintController">

    <top>
        <HBox spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="ICRS | Intelligent Complaint Resolution System" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 18;" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="180.0" spacing="10" style="-fx-background-color: #34495e; -fx-padding: 15;">
            <Button maxWidth="Infinity" text="🏠 Dashboard" style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
            <Button maxWidth="Infinity" text="📁 My History" style="-fx-background-color: transparent; -fx-text-fill: white;" />
            <Separator />
            <Button maxWidth="Infinity" text="⚙ Settings" style="-fx-background-color: transparent; -fx-text-fill: white;" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #ffffff;">
            <children>
                <Label text="New Complaint Submission" style="-fx-font-size: 20; -fx-font-weight: bold;" />
                <TextArea fx:id="complaintInput" prefHeight="250.0" promptText="Enter complaint details..." wrapText="true" />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button onAction="#handleFileUpload" text="📎 Attach Documents" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" />
                    <Label fx:id="fileNameLabel" text="No file selected" textFill="#7f8c8d" />
                </HBox>

                <Button onAction="#handleSubmit" prefHeight="50" prefWidth="250" text="Submit to AI Agent"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" />
                <Label fx:id="statusLabel" text="Ready" />
            </children>
        </VBox>
    </center>

</BorderPane>